<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- RTI Connext DDS 7.x is not published to nuget.org; packages come from the RTI installer
         and are cached locally. This source lets NuGet restore find Rti.ConnextDds 7.7.0 offline. -->
    <add key="LocalNuGetCache" value="%USERPROFILE%\.nuget\packages" />
  </packageSources>
</configuration>

